{
  "manifest_version": 3,
  "name": "Prof Preview for BYUI",
  "version": "0.1.1",
  "description": "Shows Rate My Professors ratings next to BYU-Idaho instructors during registration.",
  "permissions": [],
  "host_permissions": [
    "https://*.byui.edu/*",
    "https://www.ratemyprofessors.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.byui.edu/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
